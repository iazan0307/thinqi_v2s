// ThinQi V2 — Prisma Schema
// PostgreSQL + todas as entidades do domínio financeiro

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum RegimeTributario {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

enum TipoArquivo {
  OFX
  CSV
  PLANILHA
}

enum StatusArquivo {
  PENDENTE
  PROCESSANDO
  PROCESSADO
  CONFIRMADO
  ERRO
}

enum TipoTransacao {
  ENTRADA
  SAIDA
}

enum Role {
  ADMIN
  CONTADOR
  CLIENTE
}

// Perfil do usuário CLIENTE. SOCIO vê tudo; SECRETARIA não vê retiradas/distribuição de sócios.
enum PerfilCliente {
  SOCIO
  SECRETARIA
}

enum StatusRelatorio {
  OK
  AVISO
  ALERTA
}

// ─── Entidades principais ─────────────────────────────────────────────────────

model Empresa {
  id                String           @id @default(cuid())
  razao_social      String
  cnpj              String           @unique
  regime_tributario RegimeTributario @default(SIMPLES_NACIONAL)
  saldo_inicial     Decimal          @default(0) @db.Decimal(14, 2) // Saldo de caixa no início da primeira importação — compõe o cálculo de caixa livre no portal
  ativo             Boolean          @default(true)
  // Janela do histórico de estimativas exposto ao cliente no portal:
  //   null = todos os meses (default)
  //   1    = apenas o mês mais recente
  //   N    = últimos N meses (ex: 6)
  estimativa_historico_meses Int?
  created_at        DateTime         @default(now())
  updated_at        DateTime         @updatedAt

  // Relações
  socios               Socio[]
  arquivos             ArquivoUpload[]
  transacoes_bancarias TransacaoBancaria[]
  transacoes_cartao    TransacaoCartao[]
  faturamentos         Faturamento[]
  retiradas            RetiradaSocio[]
  relatorios           RelatorioDesconforto[]
  usuarios             Usuario[]
  estimativas_imposto  EstimativaImpostoPDF[]
  modulos              EmpresaModulo[]
  contas_bancarias     ContaBancaria[]

  @@map("empresas")
}

// Conta bancária do cliente — cadastrada via upload de OFX. Usada como
// chave primária de roteamento no upload em lote: BANKID + ACCTID do OFX
// → ContaBancaria → Empresa. O CNPJ do titular não está nos OFX brasileiros
// confirmados (Bradesco, Inter, Itaú), então este cadastro é a única forma
// confiável de identificar o dono de um extrato.
model ContaBancaria {
  id              String   @id @default(cuid())
  empresa_id      String
  bank_id         String   // Código FEBRABAN (ex: "237", "077", "341") — campo BANKID do OFX
  bank_name       String   // Nome do banco para exibição (ex: "Bradesco")
  agencia         String?  // BRANCHID do OFX, se presente
  acct_id         String   // ACCTID normalizado (sem hífen, espaços, letras)
  acct_id_display String?  // ACCTID como aparece no OFX original (com dígito/hífen)
  account_type    String?  // ACCTTYPE do OFX: "CHECKING", "SAVINGS", etc.
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  empresa Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)

  // Mesmo (banco, conta) NUNCA pode estar em duas empresas — garantia de
  // unicidade no roteamento automático.
  @@unique([bank_id, acct_id])
  @@index([empresa_id])
  @@map("contas_bancarias")
}

// Catálogo de módulos comercializáveis pelo escritório. Toggle por empresa via
// EmpresaModulo (relação many-to-many com payload de habilitação).
model Modulo {
  id         String   @id @default(cuid())
  codigo     String   @unique // identificador estável usado no código (ex: "auditoria_socios")
  nome       String
  descricao  String?
  ordem      Int      @default(0)
  ativo      Boolean  @default(true) // false desativa o módulo no catálogo (não habilitável)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  empresas EmpresaModulo[]

  @@map("modulos")
}

model EmpresaModulo {
  id              String    @id @default(cuid())
  empresa_id      String
  modulo_id       String
  habilitado      Boolean   @default(true)
  habilitado_em   DateTime  @default(now())
  desabilitado_em DateTime?
  observacao      String?

  empresa Empresa @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  modulo  Modulo  @relation(fields: [modulo_id], references: [id], onDelete: Cascade)

  @@unique([empresa_id, modulo_id])
  @@index([empresa_id])
  @@map("empresa_modulos")
}

model EstimativaImpostoPDF {
  id            String   @id @default(cuid())
  empresa_id    String
  mes_ref       DateTime @db.Date // dia 01 do mês de referência
  pdf_path      String // caminho relativo do arquivo em /uploads
  nome_original String // nome do arquivo originalmente enviado
  tamanho_bytes Int
  // Total geral extraído do PDF (campo "TOTAL" principal). Usado pelo portal
  // do cliente para exibir o valor previsto sem precisar abrir o PDF.
  valor_total   Decimal  @default(0) @db.Decimal(14, 2)
  // Payload completo do parser (cnpj detectado, mês detectado, valor total,
  // tributos individuais quando extraídos). Útil pra debugging e pra futura
  // exibição de breakdown por tributo. JSONB no Postgres → consulta indexada.
  extracted_data Json?
  uploaded_by   String // usuario_id
  uploaded_at   DateTime @default(now())
  // Soft delete: registros nunca são removidos fisicamente; ficam ocultos
  // das listagens via `deleted_at IS NULL` mas continuam acessíveis na
  // auditoria. Isso atende a Christiane (decisão da reunião): nenhum upload
  // de estimativa é descartado, mesmo após admin decidir "remover".
  deleted_at    DateTime?
  deleted_by    String?

  empresa Empresa @relation(fields: [empresa_id], references: [id])

  // Sem unique([empresa_id, mes_ref]) → permite manter histórico de uploads
  // por mês. A versão exibida no portal é sempre a mais recente (uploaded_at desc).
  @@index([empresa_id, mes_ref])
  @@index([empresa_id, deleted_at])
  @@map("estimativas_imposto_pdf")
}

model Socio {
  id                     String   @id @default(cuid())
  empresa_id             String
  nome                   String
  // CPF armazenado com hash para LGPD; os 3 primeiros + 2 últimos dígitos ficam
  // em campos separados para permitir o regex de matching
  cpf_hash               String // bcrypt hash do CPF completo
  cpf_prefixo            String // 3 primeiros dígitos (ex: "123")
  cpf_sufixo             String // 2 últimos dígitos (ex: "45")
  cpf_mascara            String // Exibição mascarada: "123.***.***-45"
  percentual_societario  Decimal  @db.Decimal(5, 2)
  limite_isencao         Decimal  @default(7640.80) @db.Decimal(12, 2) // Limite mensal isento de IR 2024
  tem_prolabore          Boolean  @default(false) // Indica se o sócio recebe pró-labore (folha) além de distribuição de lucros
  valor_prolabore_mensal Decimal  @default(0) @db.Decimal(12, 2) // Valor mensal do pró-labore; descontado do total de retiradas antes de avaliar tributação
  ativo                  Boolean  @default(true)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  // Relações
  empresa               Empresa             @relation(fields: [empresa_id], references: [id], onDelete: Cascade)
  transacoes_vinculadas TransacaoBancaria[]
  retiradas             RetiradaSocio[]

  @@map("socios")
}

model ArquivoUpload {
  id            String        @id @default(cuid())
  empresa_id    String
  tipo          TipoArquivo
  nome_original String
  nome_storage  String // Nome no disco/S3
  tamanho_bytes Int
  // SHA-256 do conteúdo do arquivo (hex). Usado para deduplicação:
  // (empresa_id, hash_sha256) é único entre uploads CONFIRMADOS — antes de criar
  // um novo registro, o handler verifica se já existe e bloqueia/avisa.
  hash_sha256   String?
  status        StatusArquivo @default(PENDENTE)
  mensagem_erro String?
  uploaded_by   String // usuario_id
  uploaded_at   DateTime      @default(now())
  processado_at DateTime?
  confirmado_at DateTime?

  // Relações
  empresa              Empresa             @relation(fields: [empresa_id], references: [id])
  uploader             Usuario             @relation(fields: [uploaded_by], references: [id])
  transacoes_bancarias TransacaoBancaria[]
  transacoes_cartao    TransacaoCartao[]
  faturamentos         Faturamento[]

  @@index([empresa_id, hash_sha256])
  @@map("arquivos_upload")
}

model TransacaoBancaria {
  id               String        @id @default(cuid())
  arquivo_id       String
  empresa_id       String
  data             DateTime      @db.Date
  descricao        String
  valor            Decimal       @db.Decimal(12, 2)
  tipo             TipoTransacao
  cpf_detectado    String? // CPF mascarado do sócio identificado (LGPD)
  nome_contraparte String? // Nome extraído do campo NAME do OFX (auditoria)
  confianca        Decimal?      @db.Decimal(5, 2) // 0-100, percentual de confiança do match
  sinal_deteccao   String? // cpf_hash | cpf_parcial | prefixo_sufixo | prefixo | nome | none
  socio_id         String? // Preenchido quando match ≥ 70% e sócio identificado
  created_at       DateTime      @default(now())

  // Relações
  arquivo ArquivoUpload @relation(fields: [arquivo_id], references: [id])
  empresa Empresa       @relation(fields: [empresa_id], references: [id])
  socio   Socio?        @relation(fields: [socio_id], references: [id])

  @@map("transacoes_bancarias")
}

model TransacaoCartao {
  id            String   @id @default(cuid())
  arquivo_id    String
  empresa_id    String
  data          DateTime @db.Date
  bandeira      String // VISA, MASTER, ELO, etc.
  adquirente    String // CIELO, STONE, REDE, PAGSEGURO, etc.
  valor_bruto   Decimal  @db.Decimal(12, 2)
  taxa          Decimal  @db.Decimal(5, 4) // Ex: 0.0199 = 1,99%
  valor_liquido Decimal  @db.Decimal(12, 2)
  created_at    DateTime @default(now())

  // Relações
  arquivo ArquivoUpload @relation(fields: [arquivo_id], references: [id])
  empresa Empresa       @relation(fields: [empresa_id], references: [id])

  @@map("transacoes_cartao")
}

model Faturamento {
  id                  String   @id @default(cuid())
  arquivo_id          String
  empresa_id          String
  mes_ref             DateTime @db.Date // Sempre dia 01 do mês de referência
  valor_total_nf      Decimal  @db.Decimal(12, 2) // Soma Valor Serviço (bruto) das NFs válidas
  valor_liquido_total Decimal  @default(0) @db.Decimal(12, 2) // Soma Valor Líquido das NFs válidas
  total_retencoes     Decimal  @default(0) @db.Decimal(12, 2) // PIS+COFINS+CSLL+IRRF+Prev retidos
  qtd_notas           Int // Notas válidas
  qtd_canceladas      Int      @default(0)
  cnpj_emitente       String? // CNPJ do emitente conforme planilha
  nome_emitente       String? // Razão social conforme planilha
  furos_sequencia     Json? // Array de { nota_faltante, alerta } da aba Auditoria de Quebras
  created_at          DateTime @default(now())

  // Relações
  arquivo ArquivoUpload @relation(fields: [arquivo_id], references: [id])
  empresa Empresa       @relation(fields: [empresa_id], references: [id])

  @@unique([empresa_id, mes_ref])
  @@map("faturamentos")
}

model RetiradaSocio {
  id                 String   @id @default(cuid())
  empresa_id         String
  socio_id           String
  mes_ref            DateTime @db.Date // Sempre dia 01 do mês de referência
  valor_total        Decimal  @db.Decimal(12, 2)
  qtd_transferencias Int
  alerta_limite      Boolean  @default(false) // true quando valor_total > limite_isencao do sócio
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  // Relações
  empresa Empresa @relation(fields: [empresa_id], references: [id])
  socio   Socio   @relation(fields: [socio_id], references: [id])

  @@unique([empresa_id, socio_id, mes_ref])
  @@map("retiradas_socios")
}

model RelatorioDesconforto {
  id                        String          @id @default(cuid())
  empresa_id                String
  mes_ref                   DateTime        @db.Date
  total_entradas            Decimal         @db.Decimal(12, 2)
  total_faturado            Decimal         @db.Decimal(12, 2)
  total_cartao              Decimal         @db.Decimal(12, 2)
  diferenca                 Decimal         @db.Decimal(12, 2) // total_entradas - total_faturado
  percentual_inconsistencia Decimal         @db.Decimal(5, 2) // (diferenca / total_entradas) * 100
  status                    StatusRelatorio // OK < 2%, AVISO 2-5%, ALERTA > 5%
  pdf_path                  String? // Caminho do PDF gerado
  enviado_em                DateTime? // Data do envio por e-mail
  liberado                  Boolean         @default(false) // true = contador liberou para o cliente visualizar
  created_at                DateTime        @default(now())
  updated_at                DateTime        @updatedAt

  // Relações
  empresa Empresa @relation(fields: [empresa_id], references: [id])

  @@unique([empresa_id, mes_ref])
  @@map("relatorios_desconforto")
}

model Usuario {
  id                  String        @id @default(cuid())
  empresa_id          String? // null = usuário ThinQi (ADMIN/CONTADOR); preenchido = cliente
  nome                String
  email               String        @unique
  senha_hash          String
  role                Role          @default(CLIENTE)
  perfil_cliente      PerfilCliente @default(SOCIO) // Só é considerado quando role = CLIENTE
  ativo               Boolean       @default(true)
  // Controle de refresh tokens (armazenado hash para segurança)
  refresh_token_hash  String?
  ultimo_login        DateTime?
  // Redefinição de senha
  reset_token_hash    String?
  reset_token_expires DateTime?
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  // Relações
  empresa     Empresa?        @relation(fields: [empresa_id], references: [id])
  uploads     ArquivoUpload[]
  audit_logs  AuditLog[]      @relation("AuditLogUsuario")

  @@map("usuarios")
}

// Auditoria de operações sensíveis: criação/edição/remoção de uploads, clientes,
// empresas, usuários e configurações. Registros são imutáveis (apenas inserts) —
// preservam histórico mesmo após o usuário ou recurso original ser removido.
model AuditLog {
  id          String   @id @default(cuid())
  acao        String   // "DELETE_UPLOAD" | "SOFT_DELETE_CLIENTE" | "UPDATE_PERFIL" | etc.
  entidade    String   // "ArquivoUpload" | "Usuario" | "Empresa" | "ContaBancaria" | ...
  entidade_id String?  // ID do recurso afetado (pode ser null se já removido / coleção)
  usuario_id  String?  // Quem executou (null em ações de sistema). FK opcional para preservar log mesmo após delete do usuário.
  empresa_id  String?  // Empresa afetada (para filtragem rápida)
  detalhes    Json?    // Payload com contexto: campos antigos/novos, contagens, mensagens
  ip          String?  // IP da requisição (quando disponível)
  user_agent  String?  // User-Agent (auditoria de origem)
  created_at  DateTime @default(now())

  usuario Usuario? @relation("AuditLogUsuario", fields: [usuario_id], references: [id], onDelete: SetNull)

  @@index([acao])
  @@index([entidade, entidade_id])
  @@index([usuario_id])
  @@index([empresa_id])
  @@index([created_at])
  @@map("audit_logs")
}
